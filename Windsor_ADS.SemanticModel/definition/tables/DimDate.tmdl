		annotation SummarizationSetBy = Automatic

	partition DimDate = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS (
				    CALENDAR(
				        MIN('gg_map'[Ngày đánh giá]),
				        MAX('gg_map'[Ngày đánh giá])
				    ),
				    "Year", YEAR ( [Date] ),
				    "Month", MONTH ( [Date] ),
				    "Month label", FORMAT ( [Date], "YYYY" ) & "M" & FORMAT ( [Date], "MM" ),
				    "WeekNum", WEEKNUM ( [Date], 2 ),
				    "WeekYear", YEAR ( [Date] - WEEKDAY ( [Date], 2 ) + 4 ),
				    "Week label",
				        YEAR ([Date]) 
				        & IF(LEN(WEEKNUM([Date],2))=1, CONCATENATE("W0",WEEKNUM([Date],2)), CONCATENATE("W", WEEKNUM([DATE],2))),
				    "DateKey", FORMAT([Date], "YYYYMMDD")
				)
				```

	annotation PBI_Id = 8e28b0473ee84e3dbb8082fa12801590

