	column shortName =
			
			-- Sử dụng biến để code dễ đọc hơn
			VAR FullName = TRIM ( [Cửa hàng] ) -- Luôn làm sạch khoảng trắng thừa trước
			VAR FullNameAsPath = SUBSTITUTE ( FullName, " ", "|" ) -- Chuyển chuỗi thành dạng path (VD: "DDV|79|Đồng|Khởi")
			
			-- Tách các thành phần của tên ra một cách an toàn
			VAR Brand = PATHITEM ( FullNameAsPath, 1, TEXT )
			VAR Number = PATHITEM ( FullNameAsPath, 2, TEXT )
			VAR Word3 = PATHITEM ( FullNameAsPath, 3, TEXT )
			VAR Word4 = PATHITEM ( FullNameAsPath, 4, TEXT )
			VAR Word5 = PATHITEM ( FullNameAsPath, 5, TEXT ) -- Thêm các Word khác nếu cần
			
			-- Lấy chữ cái đầu của các từ một cách an toàn (tránh lỗi nếu từ đó không tồn tại)
			VAR Initial3 = IF ( Word3 <> BLANK (), LEFT ( Word3, 1 ), "" )
			VAR Initial4 = IF ( Word4 <> BLANK (), LEFT ( Word4, 1 ), "" )
			VAR Initial5 = IF ( Word5 <> BLANK (), LEFT ( Word5, 1 ), "" ) -- Thêm các Initial khác nếu cần
			
			-- Tạo ra shortName theo logic
			VAR GeneratedShortName = Brand & "_" & Number & Initial3 & Initial4 & Initial5
			
			RETURN
			    -- Chỉ áp dụng logic nếu thương hiệu là "DDV"
			    IF (
			        Brand = "DDV",
			        GeneratedShortName,
			        FullName -- Giữ nguyên tên gốc cho các thương hiệu khác (VD: Bear, Vertu...)
			    )
		lineageTag: 3aab587b-c7fb-48ef-a795-6c0a26d1e256
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

