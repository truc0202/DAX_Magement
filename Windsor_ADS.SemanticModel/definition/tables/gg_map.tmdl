	measure 'Rating TB' = AVERAGE(gg_map[Sao đánh giá])
		lineageTag: ef90d21f-e414-407e-a15a-a1ebab07a958

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% CHANGE SL' =
			
			VAR SelectedDate = MAX('DimDate'[Date])
			VAR CurrentWeek = WEEKNUM(SelectedDate, 2)
			VAR CurrentYear = YEAR(SelectedDate)
			
			VAR SL_previous =
			SWITCH(
			    SELECTEDVALUE(Prm_date[Parameter Order]),
			    0, CALCULATE([SL review], DATEADD(DimDate[Date],-1, DAY), REMOVEFILTERS(DimDate)),
			    1, CALCULATE([SL review],
			        REMOVEFILTERS('DimDate'),
			            FILTER(
			                ALL('DimDate'),
			                VAR LastWeekDate = SelectedDate - 7
			                VAR TargetYear = YEAR(LastWeekDate)
			                VAR TargetWeek = WEEKNUM(LastWeekDate, 2)
			                RETURN 'DimDate'[Year] = TargetYear && 'DimDate'[WeekNum] = TargetWeek
			            )
			    ),
			    2, CALCULATE([SL review], DATEADD(DimDate[Date],-1, MONTH), REMOVEFILTERS(DimDate))
			)
			VAR SL_current = [SL review]
			VAR change_mom = IF(ISBLANK(SL_previous), 0, (SL_current - SL_previous) / SL_previous)
			
			RETURN
			    change_mom
		formatString: 0
		lineageTag: e0a8e097-4e01-486b-b2be-73a34174de24

	measure 'Rating TB (ngày/tháng/năm) - hiện tại' = ```
			
			VAR TodayDate = MAX(DimDate[Date])
			RETURN
			CALCULATE(
			    [Rating Score],
			    FILTER(
			        ALL ( 'DimDate' ),
			        SWITCH(
			            SELECTEDVALUE ( Prm_date[Parameter Order] ),
			
			            0, 'DimDate'[Date] = TodayDate,
			
			            1,
			                'DimDate'[WeekYear] = YEAR ( TodayDate - WEEKDAY ( TodayDate, 2 ) + 4 )
			                && 'DimDate'[WeekNum] = WEEKNUM ( TodayDate, 2 ),
			
			            2,
			                'DimDate'[Year] = YEAR ( TodayDate )
			                && 'DimDate'[Month] = MONTH ( TodayDate )
			        )
			    )
			)
			
			```
		lineageTag: 95aa11b7-e655-4665-9ecf-d475d827ecc4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'SL review (ngày/tháng/năm) - hiện tại' =
			
			VAR TodayDate = MAX(DimDate[Date])
			RETURN
			CALCULATE(
			    [SL review],
			    FILTER(
			        ALL ( 'DimDate' ),
			        SWITCH(
			            SELECTEDVALUE ( Prm_date[Parameter Order] ),
			
			            -- Day
			            0, 'DimDate'[Date] = TodayDate,
			
			            -- Week (ISO Mon–Sun)
			            1,
			                'DimDate'[WeekYear] = YEAR ( TodayDate - WEEKDAY ( TodayDate, 2 ) + 4 )
			                && 'DimDate'[WeekNum] = WEEKNUM ( TodayDate, 2 ),
			
			            -- Month
			            2,
			                'DimDate'[Year] = YEAR ( TodayDate )
			                && 'DimDate'[Month] = MONTH ( TodayDate )
			        )
			    )
			)
		formatString: 0
		lineageTag: 4abacbd1-29a0-4e2f-90b9-e4725909bac0

	measure 'Rating Score' = ```
			
			VAR LastVisibleDate = MAX(DimDate[Date] )
			//Tổng số sao hiện tại của các cửa hàng
			VAR SumRatingNow =  
			CALCULATE(
			    SUMX(
			        VALUES('gg_map'[Cửa hàng]),
			        CALCULATE(MAX('gg_map'[AVG Rating Total]) * MAX('gg_map'[Review Total]))
			    ),
			    REMOVEFILTERS(DimDate)
			)
			
			//Tổng reviews hiện tại của các cửa hàng
			VAR ReviewsNow = 
			CALCULATE(
			    SUMX(
			        VALUES('gg_map'[Cửa hàng]),
			        CALCULATE(MAX('gg_map'[Review Total]))
			    ),
			    REMOVEFILTERS(DimDate)
			)
			
			VAR IncrementalStars =
			    CALCULATE(
			        SUM( gg_map[Sao đánh giá] ),
			        FILTER(
			            ALL( DimDate ),
			            DimDate[Date] > LastVisibleDate
			        )
			    )
			
			VAR IncrementalReviews =
			    CALCULATE(
			        COUNT( gg_map[id] ),
			        FILTER(
			            ALL( DimDate ),
			            DimDate[Date] > LastVisibleDate
			        )
			    )
			
			VAR RawRating =
			    DIVIDE(
			        SumRatingNow - IncrementalStars,
			        ReviewsNow - IncrementalReviews
			    )
			
			RETURN  
			    MIN( 5, RawRating )
			```
		lineageTag: 9dbbdbc3-181f-4cb9-96e7-17989ad217fb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Select Review Total' =
			
			VAR LastVisibleDate = MAX(DimDate[Date] )
			
			-- Snapshot hiện tại (không bị filter)
			
			VAR RatingNow =  CALCULATE(MAX(gg_map[AVG Rating Total]),REMOVEFILTERS(DimDate))
			
			VAR ReviewsNow = CALCULATE(MAX(gg_map[Review Total]),REMOVEFILTERS(DimDate))
			
			-- Phần phát sinh sau thời điểm đang xét
			VAR IncrementalStars =
			    CALCULATE(
			        SUM( gg_map[Sao đánh giá] ),
			        FILTER(
			            ALL( DimDate ),
			            DimDate[Date] > LastVisibleDate
			        )
			    )
			
			VAR IncrementalReviews =
			    CALCULATE(
			        COUNT( gg_map[id] ),
			        FILTER(
			            ALL( DimDate ),
			            DimDate[Date] > LastVisibleDate
			        )
			    )
			
			RETURN IncrementalStars
		formatString: 0
		lineageTag: 648072ac-55f3-47f5-8bd6-10b50ff498bc

