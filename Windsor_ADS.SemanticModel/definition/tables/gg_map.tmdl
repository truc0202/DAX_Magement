	measure 'Rating Web' =
			
			VAR _LatestDate =
			    MAX (gg_map[Ngày đánh giá] )
			RETURN
			CALCULATE (
			    SELECTEDVALUE( gg_map[AVG Rating Total] ),
			    gg_map[Ngày đánh giá] = _LatestDate
			)
		lineageTag: 26102c07-83f9-4b14-8683-10c93a9152ba

